# Maintainer: skint007 <archlinux.repose742@passmail.net>
# Built from source by the `paw` personal repo CI (not the official AUR).
pkgname=pz-mod-manager
pkgver=0.0.0
pkgrel=1
pkgdesc="Desktop application for managing Project Zomboid server mod lists"
arch=('any')
url="https://github.com/skint007/project-zomboid-modid"
license=('MIT')
depends=(
    'python'
    'pyside6'
    'python-requests'
)
makedepends=(
    'git'
    'python-build'
    'python-installer'
    'python-setuptools'
    'python-setuptools-scm'
    'python-wheel'
)
conflicts=('pz-mod-manager-bin' 'pz-mod-manager-git')
source=("git+${url}.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/project-zomboid-modid"
    # Clean base version (latest v-tag) + a monotonic git suffix, e.g. 0.3.1.1.r27.a1b2c3d.
    # Every commit bumps the version, so a paw rebuild always reads as an update.
    local v r h
    v=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')
    [ -n "$v" ] || v=0.0.0
    r=$(git rev-list --count HEAD)
    h=$(git rev-parse --short=7 HEAD)
    printf '%s.r%s.%s' "$v" "$r" "$h"
}

build() {
    cd "$srcdir/project-zomboid-modid"
    # setuptools-scm derives the wheel version; pin it to the base tag so the
    # build is deterministic even if the clone lacks tag metadata.
    local v
    v=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')
    [ -n "$v" ] || v=0.0.0
    export SETUPTOOLS_SCM_PRETEND_VERSION="$v"
    python -m build --wheel --no-isolation
}

package() {
    cd "$srcdir/project-zomboid-modid"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 src/pz_mod_manager/resources/icon.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/$pkgname.svg"
    install -Dm644 aur/pz-mod-manager.desktop \
        "$pkgdir/usr/share/applications/$pkgname.desktop"
}
